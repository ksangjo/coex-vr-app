# ============================================================
# 환경변수 예시 파일 (.env.example)
# ------------------------------------------------------------
# 사용법:
#   1) 이 파일을 복사해 .env 파일을 만든다.   cp .env.example .env
#   2) .env 에 실제 값을 채워 넣는다.
#   3) .env 는 .gitignore 에 등록되어 있어 저장소에 올라가지 않는다.
#      (배포 환경에서는 .env 대신 Render 대시보드 Environment 에 같은 키로 등록)
# ============================================================

# --- Django 기본 ---
# 운영용 비밀키. 아래 명령으로 새로 생성 가능:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=
# 로컬은 True, 배포는 False 권장
DJANGO_DEBUG=True

# --- 안내 문자(SMS) 스케줄러 ---
# 예약 10분 전 안내 문자 자동 발송 스케줄러 실행 여부
SCHEDULER_AUTOSTART=True

# --- SOLAPI 문자 API (https://solapi.com) ---
# SOLAPI 콘솔 > 개발/연동 > API Key 관리에서 발급
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
# SOLAPI 콘솔에 사전 등록·승인한 발신번호 (예: 0212345678)
SOLAPI_SENDER=
# True 로 두면 실제 발송·과금 없이 흐름만 점검 (API 미호출, 로그만 남김)
SOLAPI_TEST_MODE=False

# --- 외부 크론 안내문자 엔드포인트 보호용 토큰 ---
# /cron/send-reminders/?token=... 호출 시 이 값과 일치해야 동작
CRON_SECRET_TOKEN=
